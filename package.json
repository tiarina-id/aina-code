{
  "name": "ainacode",
  "version": "0.2.5",
  "description": "CLI Coding Agent powered by api.tiarina.id",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aina": "bin/aina.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "npm run build && node --test test/*.test.js",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "release:check": "npm run build && npm test && npm run lint",
    "preversion": "npm run release:check",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "agent",
    "openai",
    "tiarina",
    "coding-assistant"
  ],
  "author": "Tiarina",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiarina-id/aina-code.git"
  },
  "homepage": "https://github.com/tiarina-id/aina-code#readme",
  "bugs": {
    "url": "https://github.com/tiarina-id/aina-code/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "openai": "^4.82.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
